node_modules/
dist/
*.log

# Dados locais sensíveis: cookies de sessão, estado do browser, biblioteca.
# Por padrão ficam em ~/.notebooklm-mcp, mas ignore também qualquer cópia local.
data/
.notebooklm-mcp/
.env

# Artefatos gerados pela auto-config durante o teste F5 (a pasta dev-sandbox em si
# é versionada via README; os configs gerados, não).
dev-sandbox/.mcp.json
dev-sandbox/.cursor/

# Auto-config gerada pela extensão na raiz do workspace (caminhos absolutos
# específicos da máquina — não devem ser versionados).
/.mcp.json
/.cursor/

# Empacotamento da extensão: servidor vendorado e o .vsix gerado.
packages/extension/vendor/
*.vsix
