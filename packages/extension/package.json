{
  "name": "notebooklm-mcp-vscode",
  "displayName": "NotebookLM MCP",
  "description": "Servidor MCP para o Google NotebookLM, empacotado e auto-configurado como extensão.",
  "version": "0.1.0",
  "publisher": "your-publisher-id",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rinaldops/notebooklm-mcp.git",
    "directory": "packages/extension"
  },
  "engines": {
    "vscode": "^1.102.0",
    "node": ">=20"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "mcp",
    "notebooklm",
    "gemini",
    "model-context-protocol"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "notebooklm.login",
        "title": "NotebookLM: Login (Google)"
      },
      {
        "command": "notebooklm.status",
        "title": "NotebookLM: Status da sessão"
      },
      {
        "command": "notebooklm.listRemote",
        "title": "NotebookLM: Listar notebooks da conta"
      },
      {
        "command": "notebooklm.autoConfigure",
        "title": "NotebookLM: Auto-configurar clientes MCP (Claude Code/Cursor)"
      },
      {
        "command": "notebooklm.installBrowser",
        "title": "NotebookLM: Instalar navegador (Chromium)"
      }
    ],
    "mcpServerDefinitionProviders": [
      {
        "id": "notebooklm",
        "label": "NotebookLM MCP"
      }
    ],
    "configuration": {
      "title": "NotebookLM MCP",
      "properties": {
        "notebooklm.autoConfigureOnActivate": {
          "type": "boolean",
          "default": true,
          "description": "Ao ativar, escreve/atualiza a config MCP do Claude Code e do Cursor no workspace aberto (.mcp.json e .cursor/mcp.json). Idempotente."
        }
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "vendor": "node scripts/vendor-server.mjs",
    "package": "npm run build && npm run vendor && vsce package --no-dependencies"
  },
  "dependencies": {
    "notebooklm-mcp": "*"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/vscode": "^1.102.0",
    "@vscode/vsce": "^3.2.0",
    "tsup": "^8.3.0",
    "typescript": "^5.8.0"
  }
}
