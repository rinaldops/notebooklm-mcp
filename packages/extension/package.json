{
  "name": "notebooklm-mcp-vscode",
  "displayName": "NotebookLM MCP",
  "description": "%description%",
  "version": "0.1.2",
  "publisher": "RinaldoPS",
  "license": "MIT",
  "icon": "icon.png",
  "l10n": "./l10n",
  "repository": {
    "type": "git",
    "url": "https://github.com/rinaldops/notebooklm-mcp.git",
    "directory": "packages/extension"
  },
  "engines": {
    "vscode": "^1.102.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "mcp",
    "notebooklm",
    "gemini",
    "model-context-protocol"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "notebooklm.login",
        "title": "%cmd.login.title%"
      },
      {
        "command": "notebooklm.status",
        "title": "%cmd.status.title%"
      },
      {
        "command": "notebooklm.listRemote",
        "title": "%cmd.listRemote.title%"
      },
      {
        "command": "notebooklm.autoConfigure",
        "title": "%cmd.autoConfigure.title%"
      },
      {
        "command": "notebooklm.installBrowser",
        "title": "%cmd.installBrowser.title%"
      }
    ],
    "mcpServerDefinitionProviders": [
      {
        "id": "notebooklm",
        "label": "NotebookLM MCP"
      }
    ],
    "configuration": {
      "title": "NotebookLM MCP",
      "properties": {
        "notebooklm.autoConfigureOnActivate": {
          "type": "boolean",
          "default": true,
          "description": "%config.autoConfigure.desc%"
        }
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "vendor": "node scripts/vendor-server.mjs",
    "package": "npm run build && npm run vendor && vsce package --no-dependencies",
    "publish": "npm run build && npm run vendor && vsce publish --no-dependencies"
  },
  "dependencies": {
    "@rinaldops/notebooklm-mcp": "*"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/vscode": "^1.102.0",
    "@vscode/vsce": "^3.2.0",
    "tsup": "^8.3.0",
    "typescript": "^5.8.0"
  }
}
